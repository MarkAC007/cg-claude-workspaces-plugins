# Art Plugin - API Keys
# Copy to ~/.claude/.env and fill in your keys

# Required for nano-banana-pro (Gemini 3 Pro) — default model
GOOGLE_API_KEY=your_google_api_key_here

# Required for flux and nano-banana models (Replicate)
REPLICATE_API_TOKEN=your_replicate_token_here

# Required for gpt-image-1 model (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Required for --remove-bg flag and remove-bg command
REMOVEBG_API_KEY=your_removebg_api_key_here

# Optional: Midjourney via Discord (for /art:midjourney command only)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
MIDJOURNEY_CHANNEL_ID=your_midjourney_channel_id_here
